{
  "name": "@rsuite/charts",
  "version": "6.0.0",
  "description": "Recharts-based chart components styled for React Suite",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    "require": "./dist/index.js",
    "import": "./dist/esm/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts",
    "dev": "tsup src/index.ts --watch",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build",
    "vercel-build": "npm run build && cd docs && npm ci && npm run build",
    "lint": "eslint .",
    "test": "jest",
    "format": "prettier --write .",
    "format:check": "prettier --list-different \"{src,docs}/**/*.{ts,tsx,js}\""
  },
  "dependencies": {
    "glob": "^13.0.6",
    "recharts": "^2.15.4"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@swc-node/jest": "^1.5.2",
    "@testing-library/jest-dom": "^5.11.9",
    "@testing-library/react": "^13.4.0",
    "@types/jest": "^27.4.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.28.0",
    "@typescript-eslint/parser": "^5.28.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.17.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-react": "^7.30.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^27.5.1",
    "jest-environment-jsdom": "^27.5.1",
    "prettier": "^2.7.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rsuite/charts.git"
  },
  "author": "Doma <leishenghao@126.com>",
  "license": "MIT",
  "homepage": "https://github.com/rsuite/charts"
}
