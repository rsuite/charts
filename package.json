{
  "name": "@rsuite/charts",
  "version": "6.0.0",
  "description": "Recharts-based chart components styled for React Suite",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    "require": "./dist/index.js",
    "import": "./dist/esm/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts",
    "dev": "tsup src/index.ts --watch",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build",
    "vercel-build": "npm run build && cd docs && npm ci && npm run build",
    "lint": "eslint .",
    "test": "jest",
    "format": "prettier --write .",
    "format:check": "prettier --list-different \"{src,docs}/**/*.{ts,tsx,js}\""
  },
  "dependencies": {
    "glob": "^13.0.6",
    "recharts": "^2.15.4"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "cross-env": "^7.0.3",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-jest": "^29.3.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rsuite/charts.git"
  },
  "author": "Doma <leishenghao@126.com>",
  "license": "MIT",
  "homepage": "https://github.com/rsuite/charts"
}
