{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "types": ["vitest/globals", "node"],
    "noUnusedLocals": true,
    "noImplicitAny": false,
    "allowJs": true,
    "noEmit": true,
    "outDir": "dist",
    "rootDir": "src",
    "isolatedModules": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true
  },
  "include": ["src"]
}
